// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}


// สำหรับมังงะ
model Manga {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String   @unique
  description   String?
  coverImage    String   @map("cover_image")
  coverWidth    Int?     @map("cover_width")
  coverHeight   Int?     @map("cover_height")
  pages         String
  authorName    String?  @map("author_name")
  extraMetadata String?  @map("extra_metadata")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  isHidden      Boolean  @default(false) @map("is_hidden")

  // --- View Count & Rating ---
  viewCount     Int   @default(0) @map("view_count")
  ratingSum     Int   @default(0) @map("rating_sum")
  ratingCount   Int   @default(0) @map("rating_count")
  averageRating Float @default(0) @map("average_rating")

  // --- ความสัมพันธ์ ---
  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])
  authorId   String?   @map("author_id")
  author     Author?   @relation(fields: [authorId], references: [id])
  tags       Tag[]     @relation("MangaTags")
  ratings    MangaRating[]
  submission MangaSubmission?
  comments   Comment[]

  // --- Indexes for query optimization ---
  @@index([categoryId])
  @@index([authorId])
  @@index([viewCount(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
  @@index([isHidden])
  @@map("manga")
}

// สำหรับหมวดหมู่
model Category {
  id          String            @id @default(cuid())
  name        String            @unique
  mangas      Manga[]
  submissions MangaSubmission[]

  @@map("categories")
}

// สำหรับแท็ก
model Tag {
  id               String               @id @default(cuid())
  name             String               @unique
  mangas           Manga[]              @relation("MangaTags")
  mangaSubmissions MangaSubmissionTag[]

  @@map("tags")
}

// สำหรับผู้แต่ง
model Author {
  id          String            @id @default(cuid())
  name        String            @unique
  profileUrl  String?           @map("profile_url")
  socialLinks String?           @map("social_links")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  mangas      Manga[]
  submissions MangaSubmission[]

  @@map("authors")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  username      String?   @unique
  password      String?
  role          String    @default("user")
  isBanned      Boolean   @default(false) @map("is_banned")
  banReason     String?   @map("ban_reason")
  bannedAt      DateTime? @map("banned_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts        Account[]
  sessions        Session[]
  submissions     MangaSubmission[]
  submissionLimit UserSubmissionLimit?
  comments        Comment[]
  commentVotes    CommentVote[]

  @@map("profiles")
}

// Better Auth Account model
model Account {
  id                    String    @id @default(cuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  expiresAt             DateTime? @map("expires_at")
  password              String?
  scope                 String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

// Better Auth Session model
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Better Auth verification model
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([identifier])
  @@map("verification")
}


model MangaSubmission {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String
  slug          String?
  description   String?
  coverImage    String               @map("cover_image")
  pages         String
  categoryId    String?              @map("category_id")
  category      Category?            @relation(fields: [categoryId], references: [id])
  authorId      String?              @map("author_id")
  author        Author?              @relation(fields: [authorId], references: [id])
  tags          MangaSubmissionTag[]
  extraMetadata String?              @map("extra_metadata")

  status          String    @default("PENDING")
  submittedAt     DateTime  @default(now()) @map("submitted_at")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?   @map("reviewed_by")
  reviewNote      String?   @map("review_note")
  rejectionReason String?   @map("rejection_reason")

  approvedMangaId String? @unique @map("approved_manga_id")
  approvedManga   Manga?  @relation(fields: [approvedMangaId], references: [id])

  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@map("manga_submissions")
}

model MangaSubmissionTag {
  id           String          @id @default(cuid())
  submissionId String          @map("submission_id")
  submission   MangaSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  tagId        String          @map("tag_id")
  tag          Tag             @relation(fields: [tagId], references: [id])

  @@unique([submissionId, tagId])
  @@map("manga_submission_tags")
}

model UserSubmissionLimit {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissionCount Int      @default(0) @map("submission_count")
  windowStart     DateTime @default(now()) @map("window_start")
  lastSubmitAt    DateTime @default(now()) @map("last_submit_at")

  @@index([userId])
  @@map("user_submission_limits")
}

// สำหรับเก็บคะแนนของผู้ใช้ (ใช้ Hybrid Approach)
model MangaRating {
  id          String   @id @default(cuid())
  mangaId     String   @map("manga_id")
  fingerprint String
  ipAddress   String?  @map("ip_address")
  rating      Int
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  manga Manga @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([mangaId, fingerprint])
  @@index([mangaId])
  @@index([fingerprint])
  @@map("manga_ratings")
}

model LoginAttempt {
  identifier String   @id
  count      Int      @default(0)
  expiresAt  DateTime @map("expires_at")

  @@map("login_attempts")
}

model SystemConfig {
  key         String  @id
  value       String
  description String?

  @@map("system_config")
}

// ====== Comment System Models ======

// Comment Model - รองรับทั้ง general และ per-image comments
model Comment {
  id       String  @id @default(cuid())
  content  String
  imageUrl String? @map("image_url")

  // Relationship
  mangaId String @map("manga_id")
  manga   Manga  @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Per-image index (null = general comment, 0-N = specific page)
  imageIndex Int? @map("image_index")

  // Parent for nested replies (phase 2)
  parentId String?   @map("parent_id")
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  // Vote summary (cached for performance)
  voteScore Int @default(0) @map("vote_score")

  votes CommentVote[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([mangaId])
  @@index([mangaId, imageIndex])
  @@index([userId])
  @@map("comments")
}

// Vote Model - เก็บ vote แยกเพื่อ track ว่าใครโหวตแล้ว
model CommentVote {
  id    String @id @default(cuid())
  value Int

  commentId String  @map("comment_id")
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([commentId, userId])
  @@index([commentId])
  @@map("comment_votes")
}

// สำหรับโฆษณา/Affiliate/Donation
model Advertisement {
  id          String   @id @default(cuid())
  type        String
  title       String
  imageUrl    String   @map("image_url")
  linkUrl     String?  @map("link_url")
  content     String?
  placement   String
  repeatCount Int      @default(1) @map("repeat_count")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("advertisements")
}
